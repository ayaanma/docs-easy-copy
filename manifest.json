{
  "manifest_version": 3,
  "name": "Docs Easy Copy",
  "short_name": "Docs Easy Copy",
  "version": "1.0.0",
  "description": "Adds a 'Make a copy' button to the 3-dot menu on the Google Docs homepage, so you can duplicate any document in one click.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://docs.google.com/document/d/*/copy*"],
      "js": ["autocopy.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
